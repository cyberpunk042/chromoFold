#!/usr/bin/env python3
import os, sys
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))
from _hooklib import *  # noqa: F401,F403
"""multi-tenant-overload: drive >=2 tenants past admission, verify isolation and BOUNDED rejection.
Cross-tenant isolation is checked from the runtime snapshot's cross_tenant_violations when available."""
t = Timer(); p = read_payload(); ep = guard_runtime(t, p)
before = snapshot(p)
n = int(p.get("requests", 40))
a = issue_requests(ep, n, tenant="tenant-a")
b = issue_requests(ep, n, tenant="tenant-b")
if a[0] == 0 or b[0] == 0:
    incomplete(t, "multi-tenant-overload: no generation capability to drive tenants")
started = a[0] + b[0]; completed = a[1] + b[1]; failed = a[2] + b[2]
if a[1] == 0 or b[1] == 0:
    fail(t, "multi-tenant-overload: a tenant was fully starved (not isolated)", requests_started=started, requests_completed=completed, requests_failed=failed)
after = snapshot(p)
if isinstance(after, dict) and int(after.get("cross_tenant_violations", 0)) != 0:
    fail(t, "multi-tenant-overload: cross-tenant contamination observed", requests_started=started, requests_completed=completed, requests_failed=failed)
recon, why = references_reconciled(before, after)
if after is None:
    incomplete(t, "multi-tenant-overload: no snapshot source to verify isolation (cross_tenant_violations) or reconciliation")
if not recon:
    incomplete(t, f"multi-tenant-overload: could not verify reference reconciliation — {why}")
emit("PASS", t, requests_started=started, requests_completed=completed, requests_failed=failed, references_reconciled=recon,
     observations=[{"operation": "two-tenant-overload", "tenant_a_completed": a[1], "tenant_b_completed": b[1], "bounded_rejections": failed, "reconcile": why}])
