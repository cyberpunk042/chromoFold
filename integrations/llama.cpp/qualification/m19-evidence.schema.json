{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ChromoFold M19 Qualification Evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["release", "telemetry", "slo", "correctness", "operations", "promotion", "shutdown"],
  "properties": {
    "release": {"type": "object", "required": ["version", "qualified_digest", "promoted_digest"], "properties": {"version": {"type": "string", "minLength": 1}, "qualified_digest": {"type": "string", "minLength": 16}, "promoted_digest": {"type": "string", "minLength": 16}}},
    "telemetry": {"type": "object", "required": ["end_to_end_traces", "correlated_records", "prompt_content_leaks", "bounded_cardinality", "incident_bundle_redacted"], "properties": {"end_to_end_traces": {"type": "integer", "minimum": 1}, "correlated_records": {"const": true}, "prompt_content_leaks": {"const": 0}, "bounded_cardinality": {"const": true}, "incident_bundle_redacted": {"const": true}}},
    "slo": {"type": "object", "required": ["ttft_measured", "token_latency_measured", "regressions_within_policy", "error_budget_exhausted"], "properties": {"ttft_measured": {"const": true}, "token_latency_measured": {"const": true}, "regressions_within_policy": {"const": true}, "error_budget_exhausted": {"const": false}}},
    "correctness": {"type": "object", "required": ["failures", "cross_tenant_contamination", "cuda_errors", "memory_reconciled"], "properties": {"failures": {"const": 0}, "cross_tenant_contamination": {"const": 0}, "cuda_errors": {"const": 0}, "memory_reconciled": {"const": true}}},
    "operations": {"type": "object", "required": ["cache_cold", "cache_warm", "multi_tenant_overload", "cancellation_cleanup", "worker_recovery", "network_fault_recovery", "certificate_rotation", "rolling_upgrade", "rollback", "autoscaling_response", "steady_state_growth_bytes"], "properties": {"cache_cold": {"const": true}, "cache_warm": {"const": true}, "multi_tenant_overload": {"const": true}, "cancellation_cleanup": {"const": true}, "worker_recovery": {"const": true}, "network_fault_recovery": {"const": true}, "certificate_rotation": {"const": true}, "rolling_upgrade": {"const": true}, "rollback": {"const": true}, "autoscaling_response": {"const": true}, "steady_state_growth_bytes": {"const": 0}}},
    "promotion": {"type": "object", "required": ["same_digest", "qualification_approved"], "properties": {"same_digest": {"const": true}, "qualification_approved": {"const": true}}},
    "shutdown": {"type": "object", "required": ["page_refs", "snapshot_refs", "lease_refs", "request_refs"], "properties": {"page_refs": {"const": 0}, "snapshot_refs": {"const": 0}, "lease_refs": {"const": 0}, "request_refs": {"const": 0}}}
  }
}
